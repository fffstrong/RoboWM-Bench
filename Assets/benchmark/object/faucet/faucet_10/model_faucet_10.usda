#usda 1.0
(
    customLayerData = {
        dictionary cameraSettings = {
            dictionary Front = {
                double3 position = (5, 0, 0)
                double radius = 5
            }
            dictionary Perspective = {
                double3 position = (0.0376317100435736, -0.5989920503347324, 0.38459953209416353)
                double3 target = (-0.013977058516787627, -0.02246194911875332, 0.13512798877464166)
            }
            dictionary Right = {
                double3 position = (0, -5, 0)
                double radius = 5
            }
            dictionary Top = {
                double3 position = (0, 0, 5)
                double radius = 5
            }
            string boundCamera = "/OmniverseKit_Persp"
        }
        dictionary omni_layer = {
            string authoring_layer = "./model_faucet_10.usda"
        }
        dictionary renderSettings = {
            double "rtx:translucency:worldEps" = 0.05
        }
    }
    defaultPrim = "root"
    metersPerUnit = 1
    subLayers = [
        @./resource/material.usda@,
        @./resource/v_0/link_default_0.usda@
    ]
    upAxis = "Z"
)

over "root" (
    prepend apiSchemas = ["SemanticsAPI:Semantics_h3tO"]
    kind = "component"
)
{
    string semantic:Semantics_h3tO:params:semanticData = "faucet"
    string semantic:Semantics_h3tO:params:semanticType = "class"

    over "E_body_2" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsArticulationRootAPI", "PhysxArticulationAPI"]
    )
    {
        bool physics:kinematicEnabled = 0
        bool physics:rigidBodyEnabled = 1

        def PhysicsFixedJoint "FixedJoint"
        {
            rel physics:body1 = </root/E_body_2>
            float physics:breakForce = inf
            float physics:breakTorque = inf
            point3f physics:localPos0 = (0.0002001, -0.0001066, 0.0055873)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }

        over "P_b89486d0d9d2f7d5" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </root/materials/Steel_Stainless> (
                bindMaterialAs = "weakerThanDescendants"
            )
        }
    }

    over "E_pipe_1" (
        active = false
    )
    {
    }

    over "E_switch_1_3" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "SemanticsAPI:Semantics_lbsg"]
    )
    {
        bool physics:kinematicEnabled = 0
        bool physics:rigidBodyEnabled = 1
        string semantic:Semantics_lbsg:params:semanticData = "handle"
        string semantic:Semantics_lbsg:params:semanticType = "class"

        def PhysicsRevoluteJoint "RevoluteJoint_Faucet_10_right" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 10
            float drive:angular:physics:stiffness = 10
            float drive:angular:physics:targetPosition = 90
            uniform token drive:angular:physics:type = "acceleration"
            uniform token physics:axis = "Z"
            rel physics:body0 = </root/E_body_2>
            rel physics:body1 = </root/E_switch_1_3>
            float physics:breakForce = inf
            float physics:breakTorque = inf
            point3f physics:localPos0 = (0.087901, 0.0179914, 0.019983)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            float physics:lowerLimit = 0
            float physics:upperLimit = 90
        }

        over "P_9cf7a1d860caf7d5" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </root/materials/Steel_Stainless> (
                bindMaterialAs = "weakerThanDescendants"
            )
        }
    }

    over "E_switch_2_4" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "SemanticsAPI:Semantics_AdON"]
    )
    {
        bool physics:kinematicEnabled = 0
        bool physics:rigidBodyEnabled = 1
        string semantic:Semantics_AdON:params:semanticData = "handle"
        string semantic:Semantics_AdON:params:semanticType = "class"

        def PhysicsRevoluteJoint "RevoluteJoint_Faucet_10_left" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 10
            float drive:angular:physics:stiffness = 10
            float drive:angular:physics:targetPosition = -90
            uniform token drive:angular:physics:type = "acceleration"
            uniform token physics:axis = "Z"
            rel physics:body0 = </root/E_body_2>
            rel physics:body1 = </root/E_switch_2_4>
            float physics:breakForce = inf
            float physics:breakTorque = inf
            point3f physics:localPos0 = (-0.0772826, 0.0174761, 0.019983)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            float physics:lowerLimit = -90
            float physics:upperLimit = 0
        }

        over "P_d43ddbe548b6f7d5" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </root/materials/Steel_Stainless> (
                bindMaterialAs = "weakerThanDescendants"
            )
        }
    }

    over "E_switch_3_5" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "SemanticsAPI:Semantics_bHzt"]
    )
    {
        bool physics:kinematicEnabled = 0
        bool physics:rigidBodyEnabled = 1
        string semantic:Semantics_bHzt:params:semanticData = "handle"
        string semantic:Semantics_bHzt:params:semanticType = "class"

        def PhysicsRevoluteJoint "RevoluteJoint_Faucet_10_middle" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 10
            float drive:angular:physics:stiffness = 10
            float drive:angular:physics:targetPosition = -40
            uniform token drive:angular:physics:type = "acceleration"
            uniform token physics:axis = "X"
            rel physics:body0 = </root/E_body_2>
            rel physics:body1 = </root/E_switch_3_5>
            float physics:breakForce = inf
            float physics:breakTorque = inf
            point3f physics:localPos0 = (0.0385703, -0.0039345, 0.0536128)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (-0.6560589, 0.000017720928, 0.000014212011, 0.75470966)
            quatf physics:localRot1 = (1, 0, 0, 0)
            float physics:lowerLimit = -40
            float physics:upperLimit = 0
        }

        over "P_a320b61760c2f7d5" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </root/materials/Steel_Stainless> (
                bindMaterialAs = "weakerThanDescendants"
            )
        }
    }

    over "materials"
    {
        over "mat_165629"
        {
            over "PBRShader"
            {
                float inputs:clearcoat = 0.17
                float inputs:metallic = 1
                float inputs:roughness = 0.35
            }
        }

        def Material "Steel_Stainless"
        {
            token outputs:mdl:displacement.connect = </root/materials/Steel_Stainless/Shader.outputs:out>
            token outputs:mdl:surface.connect = </root/materials/Steel_Stainless/Shader.outputs:out>
            token outputs:mdl:volume.connect = </root/materials/Steel_Stainless/Shader.outputs:out>

            def Shader "Shader"
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:mdl:sourceAsset = @./NVIDIA/Materials/2023_2_1/Base/Metals/Steel_Stainless.mdl@
                uniform token info:mdl:sourceAsset:subIdentifier = "Steel_Stainless"
                token outputs:out (
                    renderType = "material"
                )
            }
        }
    }

    def Xform "E_pipe_02" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "SemanticsAPI:Semantics_7YIB"]
    )
    {
